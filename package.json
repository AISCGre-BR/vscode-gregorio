{
  "name": "vscode-gregorio",
  "displayName": "Gregorio (GABC/NABC)",
  "description": "Support for GABC/NABC Gregorian chant notation: tree-sitter-gregorio syntax highlighting, in-process diagnostics, formatting, note shifting, and empty-parentheses filling (via gregorio-core WASM).",
  "version": "0.2.1",
  "publisher": "AISCGre-BR",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e3a2f",
    "theme": "dark"
  },
  "author": {
    "name": "AISCGre Brasil"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AISCGre-BR/vscode-gregorio.git"
  },
  "bugs": {
    "url": "https://github.com/AISCGre-BR/vscode-gregorio/issues"
  },
  "homepage": "https://github.com/AISCGre-BR/vscode-gregorio#readme",
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "gabc",
    "nabc",
    "gregorian chant",
    "gregorio",
    "tree-sitter"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:gabc"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gabc",
        "aliases": [
          "GABC",
          "gabc"
        ],
        "extensions": [
          ".gabc"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "gabc",
        "scopeName": "source.gabc",
        "path": "./syntaxes/gabc.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.latex": "latex",
          "meta.embedded.inline.tex": "latex",
          "source.tex": "latex"
        }
      }
    ],
    "snippets": [
      {
        "language": "gabc",
        "path": "./snippets/gabc.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "gabc.noteShiftUp",
        "title": "Gregorio: Shift Notes Up",
        "category": "Gregorio"
      },
      {
        "command": "gabc.noteShiftDown",
        "title": "Gregorio: Shift Notes Down",
        "category": "Gregorio"
      },
      {
        "command": "gabc.fillParens",
        "title": "Gregorio: Fill Empty Note Groups",
        "category": "Gregorio"
      },
      {
        "command": "gabc.convertLigaturesToTags",
        "title": "Gregorio: Convert Ligatures to <sp> Tags",
        "category": "Gregorio"
      },
      {
        "command": "gabc.convertTagsToLigatures",
        "title": "Gregorio: Convert <sp> Tags to Ligatures",
        "category": "Gregorio"
      },
      {
        "command": "gabc.restartLanguageServer",
        "title": "Gregorio: Restart Language Server",
        "category": "Gregorio"
      }
    ],
    "keybindings": [
      {
        "command": "gabc.noteShiftUp",
        "key": "ctrl+alt+up",
        "when": "editorTextFocus && editorLangId == gabc"
      },
      {
        "command": "gabc.noteShiftDown",
        "key": "ctrl+alt+down",
        "when": "editorTextFocus && editorLangId == gabc"
      },
      {
        "command": "gabc.fillParens",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus && editorLangId == gabc"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == gabc",
          "command": "gabc.noteShiftUp",
          "group": "1_modification@1"
        },
        {
          "when": "editorLangId == gabc",
          "command": "gabc.noteShiftDown",
          "group": "1_modification@2"
        },
        {
          "when": "editorLangId == gabc",
          "command": "gabc.fillParens",
          "group": "1_modification@3"
        }
      ]
    },
    "configuration": {
      "title": "Gregorio",
      "properties": {
        "gregorio.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable language features (diagnostics, formatting, code actions). In WASM mode this controls the in-process providers; in external mode it controls whether the gregorio-lsp process is started."
        },
        "gregorio.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to an external `gregorio-lsp` binary. **Leave empty** (default) to use the built-in WASM engine — no installation required. Set to `gregorio-lsp` (bare name resolved from PATH) or an absolute path to use the external server, which additionally provides hover, completion, and document symbols. Changing this setting restarts the active language features automatically."
        },
        "gregorio.languageServer.formatting": {
          "type": "object",
          "default": {},
          "markdownDescription": "Options for the GABC formatter.",
          "properties": {
            "maxLineWidth": {
              "type": "integer",
              "default": 80,
              "description": "Maximum characters per notation line."
            },
            "breakAfterClef": {
              "type": "boolean",
              "default": false,
              "description": "Insert a line break after each clef token."
            },
            "breakAfterBar": {
              "type": "boolean",
              "default": false,
              "description": "Insert a line break after each bar token."
            }
          }
        },
        "gregorio.linting.severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "info",
          "description": "Minimum severity level of diagnostics to show."
        },
        "gregorio.linting.ignoreCodes": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Diagnostic codes to suppress."
        },
        "gregorio.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable tree-sitter-gregorio semantic highlighting, including nabc-lines-aware GABC/NABC block alternation. Falls back to the built-in tokenizer when the tree-sitter grammar (WASM) is unavailable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:lsp-wasm && npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc --noEmit -p ./",
    "lint": "tsc --noEmit -p ./",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:lsp-wasm": "bash scripts/build-lsp-wasm.sh",
    "package": "vsce package --no-dependencies",
    "test": "node --test test/transform.test.ts"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0",
    "web-tree-sitter": "^0.26.10"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.24.2": true,
    "@vscode/vsce-sign@2.0.9": true
  }
}
